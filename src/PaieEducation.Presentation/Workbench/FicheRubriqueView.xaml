<UserControl x:Class="PaieEducation.Presentation.Workbench.FicheRubriqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:controls="clr-namespace:PaieEducation.Presentation.Controls"
             mc:Ignorable="d" d:DesignWidth="800">
    <DockPanel Margin="24">
        <TextBlock Text="Fiche rubrique" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" DockPanel.Dock="Top"/>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,8" DockPanel.Dock="Top" VerticalAlignment="Bottom">
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Rubrique (code référentiel, ex. ISSRP_45)"/>
                <TextBox Text="{Binding RubriqueId, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
            </StackPanel>
            <StackPanel Margin="0,0,8,0">
                <TextBlock Text="Date de paie (AAAA-MM-JJ)"/>
                <TextBox Text="{Binding DatePaie, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
            </StackPanel>
            <Button Content="Charger" Command="{Binding ChargerCommand}" Width="100" Height="24"/>
        </StackPanel>

        <TextBlock Text="Chargement en cours…" Foreground="Gray" Margin="0,0,0,8" DockPanel.Dock="Top">
            <TextBlock.Style>
                <Style TargetType="TextBlock">
                    <Setter Property="Visibility" Value="Collapsed"/>
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding EnCours}" Value="True">
                            <Setter Property="Visibility" Value="Visible"/>
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </TextBlock.Style>
        </TextBlock>

        <TabControl>
            <!-- Identité -->
            <TabItem Header="Identité">
                <StackPanel Margin="12" DataContext="{Binding Detail}">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Libellé : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Libelle}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Nature : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Nature}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Base de calcul : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding BaseCalcul}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Périodicité (calcul) : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Periodicite}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Périodicité (versement) : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding PeriodiciteVersement}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Ordre de calcul : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding OrdreCalcul}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Imposable : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding EstImposable}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Cotisable : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding EstCotisable}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Active : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Actif}"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                        <TextBlock Text="Description : " FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding Description}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </TabItem>

            <!-- Barème -->
            <TabItem Header="Barème">
                <controls:ERPDataGrid ItemsSource="{Binding Baremes}" Margin="12">
                    <controls:ERPDataGrid.Columns>
                        <DataGridTextColumn Header="Dimension" Binding="{Binding Dimension}" Width="120"/>
                        <DataGridTextColumn Header="Borne inf." Binding="{Binding BorneInf}" Width="90"/>
                        <DataGridTextColumn Header="Borne sup." Binding="{Binding BorneSup}" Width="90"/>
                        <DataGridTextColumn Header="Type" Binding="{Binding TypeValeur}" Width="80"/>
                        <DataGridTextColumn Header="Valeur" Binding="{Binding Valeur}" Width="100"/>
                        <DataGridTextColumn Header="Date d'effet" Binding="{Binding Periode.DateEffet}" Width="100"/>
                        <DataGridTextColumn Header="Date de fin" Binding="{Binding Periode.DateFin}" Width="*"/>
                    </controls:ERPDataGrid.Columns>
                </controls:ERPDataGrid>
            </TabItem>

            <!-- Éligibilité -->
            <TabItem Header="Éligibilité">
                <controls:ERPDataGrid ItemsSource="{Binding Conditions}" Margin="12">
                    <controls:ERPDataGrid.Columns>
                        <DataGridTextColumn Header="Critère" Binding="{Binding CritereId}" Width="140"/>
                        <DataGridTextColumn Header="Opérateur" Binding="{Binding Operateur}" Width="90"/>
                        <DataGridTextColumn Header="Valeur" Binding="{Binding Valeur}" Width="160"/>
                        <DataGridTextColumn Header="Groupe" Binding="{Binding GroupeId}" Width="100"/>
                        <DataGridTextColumn Header="Date d'effet" Binding="{Binding Periode.DateEffet}" Width="100"/>
                        <DataGridTextColumn Header="Date de fin" Binding="{Binding Periode.DateFin}" Width="*"/>
                    </controls:ERPDataGrid.Columns>
                </controls:ERPDataGrid>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
