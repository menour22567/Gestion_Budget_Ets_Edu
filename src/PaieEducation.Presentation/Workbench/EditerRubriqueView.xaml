<UserControl x:Class="PaieEducation.Presentation.Workbench.EditerRubriqueView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             mc:Ignorable="d" d:DesignWidth="640">
    <DockPanel Margin="24">
        <TextBlock Text="Éditer une rubrique" FontSize="20" FontWeight="Bold" Margin="0,0,0,16" DockPanel.Dock="Top"/>

        <TabControl>
            <!-- Identité -->
            <TabItem Header="Identité">
                <StackPanel Margin="12" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="Code rubrique (ex. ISSRP_45)"/>
                    <TextBox Text="{Binding RubriqueId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Libellé"/>
                    <TextBox Text="{Binding Libelle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Nature"/>
                            <ComboBox ItemsSource="{Binding Natures}" SelectedItem="{Binding Nature}" Width="160"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Base de calcul"/>
                            <ComboBox ItemsSource="{Binding BasesCalcul}" SelectedItem="{Binding BaseCalcul}" Width="200"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Périodicité (calcul)"/>
                            <ComboBox ItemsSource="{Binding Periodicites}" SelectedItem="{Binding Periodicite}" Width="200"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Périodicité (versement, opt.)"/>
                            <TextBox Text="{Binding PeriodiciteVersement, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Ordre de calcul"/>
                            <TextBox Text="{Binding OrdreCalcul, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Source valeur (code, opt.)"/>
                            <TextBox Text="{Binding SourceValeurId, UpdateSourceTrigger=PropertyChanged}" Width="200"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <CheckBox Content="Imposable" IsChecked="{Binding EstImposable}" Margin="0,0,16,0"/>
                        <CheckBox Content="Cotisable" IsChecked="{Binding EstCotisable}" Margin="0,0,16,0"/>
                        <CheckBox Content="Affectable manuellement" IsChecked="{Binding EstAffectableManuellement}" Margin="0,0,16,0"/>
                        <CheckBox Content="Occurrences multiples" IsChecked="{Binding OccurrencesMultiples}"/>
                    </StackPanel>
                    <TextBlock Text="Description"/>
                    <TextBox Text="{Binding Description, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Source (référence réglementaire, opt.)"/>
                    <TextBox Text="{Binding Source, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Button Content="Enregistrer" Command="{Binding DefinirIdentiteCommand}" Width="140" HorizontalAlignment="Left" Margin="0,8,0,8"/>
                    <TextBlock Text="{Binding IdentiteResultat}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>

            <!-- Formule -->
            <TabItem Header="Formule">
                <StackPanel Margin="12" MaxWidth="620" HorizontalAlignment="Left">
                    <TextBlock Text="Code rubrique"/>
                    <TextBox Text="{Binding FormuleRubriqueId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>

                    <TextBlock Text="Expression (ex. TBASE * 0.45) — validation live (P10)"/>
                    <TextBox x:Name="FormuleTextBox"
                             Text="{Binding FormuleExpression, UpdateSourceTrigger=PropertyChanged}"
                             AcceptsReturn="True" Height="60" TextWrapping="Wrap" Margin="0,0,0,4">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Setter Property="BorderBrush" Value="#888"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding FormuleValidationEstValide}" Value="True">
                                        <Setter Property="BorderBrush" Value="ForestGreen"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding FormuleValidationEstValide}" Value="False">
                                        <Setter Property="BorderBrush" Value="Firebrick"/>
                                        <Setter Property="BorderThickness" Value="2"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <TextBlock x:Name="FormuleValidationIcon" VerticalAlignment="Center" Margin="0,0,6,0"
                                   FontWeight="Bold" Text="✓">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="ForestGreen"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FormuleValidationEstValide}" Value="False">
                                            <Setter Property="Foreground" Value="Firebrick"/>
                                            <Setter Property="Text" Value="✗"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding FormuleValidation}" VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- P10 : auto-complétion -->
                    <Border BorderThickness="1" BorderBrush="#DDD" Padding="8" Margin="0,0,0,8" Background="#FAFAFA">
                        <StackPanel>
                            <TextBlock Text="Auto-complétion (P10)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal">
                                <TextBox Text="{Binding CompletionPrefixe, UpdateSourceTrigger=PropertyChanged}"
                                         Width="240" Margin="0,0,8,0"
                                         ToolTip="Tapez quelques lettres puis cliquez Proposer (V1.1 : Ctrl+Espace)."/>
                                <Button Content="Proposer" Command="{Binding DemanderCompletionCommand}" Width="100" Margin="0,0,8,0"/>
                                <Button Content="Fermer" Command="{Binding FermerCompletionCommand}" Width="80"/>
                            </StackPanel>
                            <Popup IsOpen="{Binding CompletionPopupOuvert}"
                                   PlacementTarget="{Binding ElementName=FormuleTextBox}"
                                   Placement="Bottom" StaysOpen="False" Width="520" MaxHeight="260">
                                <Border BorderBrush="#888" BorderThickness="1" Background="White">
                                    <ListBox x:Name="CompletionList"
                                             ItemsSource="{Binding CompletionItems}"
                                             MaxHeight="260" Width="520"
                                             MouseDoubleClick="CompletionList_MouseDoubleClick">
                                        <ListBox.ItemTemplate>
                                            <DataTemplate>
                                                <StackPanel Orientation="Horizontal" Margin="4,2">
                                                    <TextBlock Text="{Binding Token}" FontWeight="SemiBold" Width="180" FontFamily="Consolas"/>
                                                    <TextBlock Text="{Binding Categorie}" Foreground="Gray" Width="110" FontSize="10"/>
                                                    <TextBlock Text="{Binding Description}" TextWrapping="Wrap" FontSize="11"/>
                                                </StackPanel>
                                            </DataTemplate>
                                        </ListBox.ItemTemplate>
                                    </ListBox>
                                </Border>
                            </Popup>
                            <TextBlock Text="Double-clic sur un item (ou Entrée) pour l'insérer dans l'expression."
                                       FontSize="10" Foreground="Gray" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Border>

                    <!-- P10 : simulation agent témoin -->
                    <Border BorderThickness="1" BorderBrush="#9CF" Padding="8" Margin="0,0,0,8" Background="#F0F8FF">
                        <StackPanel>
                            <TextBlock Text="Simulation agent témoin (P10 — le vrai filet)" FontWeight="SemiBold" Margin="0,0,0,4"/>
                            <StackPanel Orientation="Horizontal" Margin="0,0,0,4">
                                <StackPanel Margin="0,0,12,0">
                                    <TextBlock Text="Agent témoin"/>
                                    <ComboBox ItemsSource="{Binding AgentsTemoins}"
                                              SelectedItem="{Binding AgentTemoinSelectionne}"
                                              DisplayMemberPath="Libelle" Width="320"/>
                                </StackPanel>
                                <StackPanel>
                                    <TextBlock Text="Date de paie (AAAA-MM-JJ)"/>
                                    <TextBox Text="{Binding DatePaieSimulation, UpdateSourceTrigger=PropertyChanged}" Width="140"/>
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Charger les agents" Command="{Binding ChargerAgentsTemoinsCommand}" Width="160" Margin="0,0,8,0"/>
                                <Button Content="Simuler" Command="{Binding SimulerCommand}" Width="120"/>
                            </StackPanel>
                            <TextBlock Text="{Binding ResultatSimulation}" TextWrapping="Wrap" FontWeight="SemiBold" Margin="0,8,0,0"/>
                        </StackPanel>
                    </Border>

                    <TextBlock Text="Date d'effet (AAAA-MM-JJ)"/>
                    <TextBox Text="{Binding FormuleDateEffet, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <Button Content="Valider la syntaxe" Command="{Binding ValiderFormuleCommand}" Width="160" Margin="0,0,12,0"/>
                        <TextBlock Text="(la validation se fait déjà automatiquement à la frappe — bouton conservé pour accessibilité)"
                                   VerticalAlignment="Center" FontSize="10" Foreground="Gray" TextWrapping="Wrap" MaxWidth="380"/>
                    </StackPanel>
                    <Button Content="Enregistrer la formule" Command="{Binding DefinirFormuleCommand}" Width="200" HorizontalAlignment="Left" Margin="0,8,0,8"/>
                    <TextBlock Text="{Binding FormuleResultat}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>

            <!-- Paramètre -->
            <TabItem Header="Paramètre">
                <StackPanel Margin="12" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="Code rubrique"/>
                    <TextBox Text="{Binding ParametreRubriqueId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Clé (ex. TAUX, SEUIL)"/>
                    <TextBox Text="{Binding ParametreCle, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Valeur"/>
                    <TextBox Text="{Binding ParametreValeur, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Date d'effet (AAAA-MM-JJ)"/>
                    <TextBox Text="{Binding ParametreDateEffet, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Source (opt.)"/>
                    <TextBox Text="{Binding ParametreSource, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Button Content="Enregistrer le paramètre" Command="{Binding DefinirParametreCommand}" Width="220" HorizontalAlignment="Left" Margin="0,8,0,8"/>
                    <TextBlock Text="{Binding ParametreResultat}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>

            <!-- Barème -->
            <TabItem Header="Barème">
                <StackPanel Margin="12" MaxWidth="520" HorizontalAlignment="Left">
                    <TextBlock Text="Code rubrique"/>
                    <TextBox Text="{Binding BaremeRubriqueId, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Dimension"/>
                            <ComboBox ItemsSource="{Binding BaremeDimensions}" SelectedItem="{Binding BaremeDimension}" Width="180"/>
                        </StackPanel>
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Type de valeur"/>
                            <ComboBox ItemsSource="{Binding BaremeTypesValeur}" SelectedItem="{Binding BaremeTypeValeur}" Width="120"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                        <StackPanel Margin="0,0,12,0">
                            <TextBlock Text="Borne inférieure (clé de tranche)"/>
                            <TextBox Text="{Binding BaremeBorneInf, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        </StackPanel>
                        <StackPanel>
                            <TextBlock Text="Borne supérieure (vide = +infini)"/>
                            <TextBox Text="{Binding BaremeBorneSup, UpdateSourceTrigger=PropertyChanged}" Width="160"/>
                        </StackPanel>
                    </StackPanel>
                    <TextBlock Text="Valeur (fraction pour TAUX, entier pour MONTANT)"/>
                    <TextBox Text="{Binding BaremeValeur, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Date d'effet (AAAA-MM-JJ)"/>
                    <TextBox Text="{Binding BaremeDateEffet, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <TextBlock Text="Source (référence réglementaire, opt.)"/>
                    <TextBox Text="{Binding BaremeSource, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,8"/>
                    <Button Content="Enregistrer le barème" Command="{Binding DefinirBaremeCommand}" Width="200" HorizontalAlignment="Left" Margin="0,8,0,8"/>
                    <TextBlock Text="{Binding BaremeResultat}" TextWrapping="Wrap" FontWeight="SemiBold"/>
                </StackPanel>
            </TabItem>
        </TabControl>
    </DockPanel>
</UserControl>
